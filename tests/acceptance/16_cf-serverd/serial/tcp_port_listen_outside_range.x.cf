#
# Check the parser enforces standard TCP port ( 1 <= port <= 65535) for:
# -cf-serverd listening port
#

body common control
{
      bundlesequence => { default("$(this.promise_filename)") };
      inputs => { "../../default.sub.cf" };
      version => "1.0";
}

body server control
{
      port => "65536";
}

bundle agent test
{
  reports:
      "$(this.promise_filename) Pass";
}
