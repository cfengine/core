body common control
{
  inputs => { "../../default.cf.sub" };
  bundlesequence => { default("$(this.promise_filename)") };
  version => "1.0";
}
#######################################################

bundle agent check
{
  vars:
    "test_file"
      string => "$(this.promise_dirname)/isnewerthantime_file.txt";
    "nonexistent_file"
      string => "$(this.promise_dirname)/thisfiledoesntexist_1747148781.txt";
  classes:
    # "ok1"
    #   expression => isnewerthantime("$(test_file)", "-1");
    # error: Fatal CFEngine error: In function 'isnewerthantime', error in variable '-1', 'Integer is out of range'
    "ok2"
      expression => isnewerthantime("$(test_file)", 0);
    "ok3"
      expression => isnewerthantime("$(nonexistent_file)", 0);
    "ok4"
      expression => isnewerthantime("$(test_file)", 1747148780);
    "ok5"
      expression => isnewerthantime("$(test_file)", 1747148781);
    "ok6"
      expression => isnewerthantime("$(nonexistent_file)", 1747148781);
    "ok7"
      # as "inf" corresponds to 999999999, this is actually not False
      expression => isnewerthantime("$(test_file)", "inf");
    "ok8"
      expression => isnewerthantime("$(nonexistent_file)", "inf");
    "ok"
      expression => and("ok2", "!ok3", "ok4", "!ok5", "!ok6", "ok7", "!ok8");

  reports:
    ok::
      "$(this.promise_filename) Pass";
    !ok::
      "$(this.promise_filename) FAIL";
}
