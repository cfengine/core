body common control
{
  bundlesequence => { "check" };
  version => "1.2.3";
}
bundle agent check
{
  classes:
    "ok"
      expression => strcmp("$(sys.policy_version)", "$(default:control_common.version)");

  reports:
    ok::
      "$(this.promise_filename) Pass";
    !ok::
      "$(this.promise_filename) FAIL";
}
