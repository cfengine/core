###########################################################
#
# Test validdata() with valid and invalid data files
#
###########################################################

body common control
{
    inputs => { "../../default.cf.sub" };
    bundlesequence => { default($(this.promise_filename)) };
    version => "1.0";
}

###########################################################

bundle agent test
{
  vars:
    "valid_json" string => "should appear",
      if => validdata(readfile("$(this.promise_filename).json", inf), "JSON");
    "invalid_json" string => "should not appear",
      if => validdata(readfile("$(this.promise_filename).inv.json", inf), "JSON");

    "valid_validjson" string => "should appear",
      if => validjson(readfile("$(this.promise_filename).json", inf));
    "invalid_validjson" string => "should not appear",
      if => validjson(readfile("$(this.promise_filename).inv.json", inf));

    "valid_json_string_primitive" string => "should appear",
      if => validjson("\"hello\"", "false");
    "invalid_json_string_primitive" string => "should not appear",
      if => validjson("\"hello\"", "true")

    "valid_json_number_primitive" string => "should appear",
      if => validjson("123.45", "false");
    "invalid_json_number_primitive" string => "should not appear",
      if => validjson("123.45", "true")

    "valid_json_boolean_primitive" string => "should appear",
      if => validjson("true", "false");
    "invalid_json_boolean_primitive" string => "should not appear",
      if => validjson("true", "true")

    "valid_json_null_primitive" string => "should appear",
      if => validjson("null", "false");
    "invalid_json_null_primitive" string => "should not appear",
      if => validjson("null", "true")

}

###########################################################

bundle agent check
{
  methods:
    "check" usebundle => dcs_check_state(test,
                                         "$(this.promise_filename).expected.json",
                                         $(this.promise_filename));
}
